# apps/scraper env
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Optional: data.gov.il CKAN dataset id
DATA_GOV_RESOURCE_ID=""

# Minimum publication date (inclusive). Tenders without publicationDate are skipped.
MIN_PUBLICATION_DATE="2026-01-01T00:00:00+02:00"

# Optional: BudgetKey pagination safety cap (default 20000)
BUDGETKEY_MAX_RESULTS="20000"

# Optional: comma-separated Dekel portal base URLs to scan
DEKEL_BASE_URLS="https://bids.dekel.co.il"

