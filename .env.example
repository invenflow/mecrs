## Root env (reference)
## Copy relevant sections into:
## - apps/web/.env.local
## - apps/scraper/.env
##
## Never commit real secrets.
##
## Deployment:
## - Netlify (apps/web): set all web vars below in Site → Environment variables
## - GitHub Actions (scraper): add repository secrets:
##     SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, DATA_GOV_RESOURCE_ID (optional),
##     APP_URL (e.g. https://your-site.netlify.app), SCRAPER_CRON_SECRET

########################################
# Supabase (shared)
########################################
# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://wjewdgnfyxpsxsaiteqi.supabase.co"

# Public anon key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_XqUIqGAfam9WMyZ5rpRHmg_aDhoDKOZ"

# Service role key (Settings → API → service_role)  (SECRET!)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

########################################
# Web app (apps/web)
########################################
# Optional but recommended for redirects/links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

########################################
# Scraper cron / alerts auth
########################################
# Used to authorize POST /api/alerts/run (SECRET!)
SCRAPER_CRON_SECRET="CHANGE_ME_LONG_RANDOM"

########################################
# Resend (email alerts)
########################################
# Resend API key (SECRET!)
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"

# Verified sender email in Resend, e.g. "InvenFlow <alerts@yourdomain.com>"
ALERT_FROM_EMAIL="InvenFlow <alerts@yourdomain.com>"

########################################
# data.gov.il (optional)
########################################
# If set, scraper will also ingest CKAN dataset:
DATA_GOV_RESOURCE_ID=""

